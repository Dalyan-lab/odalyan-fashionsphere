# ============================================================
#  Odalyan FashionSphere AI — Variables de PRODUCTION
#  Copier en .env.prod et remplir. NE PAS committer .env.prod.
# ============================================================

# --- Base de données (conteneur postgres du compose) ---
POSTGRES_USER=odalyan
POSTGRES_PASSWORD=CHANGE_ME_mot_de_passe_fort
POSTGRES_DB=fashionsphere
# DATABASE_URL est calculée automatiquement par docker-compose.prod.yml

# --- URLs publiques (adapter à votre domaine) ---
# Origine(s) autorisée(s) pour le CORS de l'API (séparées par des virgules)
WEB_ORIGIN=https://votre-domaine.com
# URL publique de l'API (utilisée pour les liens d'upload et les callbacks)
API_PUBLIC_URL=https://api.votre-domaine.com
# URL de l'API vue par le navigateur (build du web) — inclure le suffixe /api
NEXT_PUBLIC_API_URL=https://api.votre-domaine.com/api

# --- JWT (générer des secrets aléatoires longs) ---
JWT_ACCESS_SECRET=CHANGE_ME_secret_access_aleatoire_long
JWT_REFRESH_SECRET=CHANGE_ME_secret_refresh_aleatoire_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Paiement Paystack (Afrique : carte + Mobile Money, XOF) ---
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_CURRENCY=XOF
PAYSTACK_EUR_RATE=655.957

# --- Stripe (optionnel, si carte hors Afrique) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Emails SMTP (mot de passe oublié, notifications) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Odalyan FashionSphere <no-reply@votre-domaine.com>

# --- Stockage objets S3 / Cloudflare R2 (recommandé en prod pour les uploads) ---
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=

# --- OAuth social (optionnel) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- IA (optionnel, sinon mode simulé) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=
HEYGEN_API_KEY=
RUNWAYML_API_SECRET=
KLING_API_KEY=

# --- Publication réseaux sociaux (optionnel, sinon publication simulée) ---
# Meta (une seule app couvre Facebook Page + Instagram Business).
# App sur developers.facebook.com → produit « Facebook Login » ;
# URL de retour OAuth valide : https://<votre-api>/api/social/oauth/callback/Facebook
#                        et : https://<votre-api>/api/social/oauth/callback/Instagram
# Publication réelle = App Review pour pages_manage_posts + instagram_content_publish.
META_APP_ID=
META_APP_SECRET=

# --- ViralAmazone : Tracker de tendances Amazon (optionnel, sinon mode démo) ---
# Amazon Product Advertising API 5.0 — clés du compte Associates (officiel, un seul
# compte pour toute la plateforme). Suffixe par marketplace optionnel si vous opérez
# plusieurs programmes Associates : _FR, _COM, _UK, _DE, _IT, _ES, _CA, _JP, _IN.
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=
# Keepa — historique de rang de vente (souscription payante sur keepa.com)
KEEPA_API_KEY=
