// Odalyan FashionSphere AI™ — Schéma de base de données (MVP Phase 1)
// Couvre : utilisateurs/auth, abonnements, boutiques (avec branding),
// produits/variantes, panier, commandes, paiements.

generator client {
  provider      = "prisma-client-js"
  // "native" pour le dev local ; "debian-openssl-3.0.x" pour l'image Docker (node:20-bookworm-slim)
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SELLER
  CUSTOMER
  MARKETING_AGENCY
}

enum SubscriptionPlan {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum ProductCategory {
  HOMME
  FEMME
  ENFANT
  LUXE
  SPORT
  ACCESSOIRES
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MOBILE_MONEY
  FLUTTERWAVE
  CINETPAY
  PAYSTACK
}

enum GeneratedAssetType {
  MANNEQUIN
  STUDIO_PHOTO
  AD_VISUAL
  AD_COPY
  AVATAR
}

enum GeneratedAssetStatus {
  PENDING
  READY
  FAILED
}

/** Classification de vélocité des produits Amazon suivis (module ViralAmazone). */
enum TrendTier {
  SUPER_NOVA // 🔴 Explosion Éclair : progression > 200% en < 12h
  HOT_WOOD // 🔥 Tendance Forte : croissance constante sur 3 jours
  SLOW_BURN // 📈 Croissance Stable : hausse régulière + avis en hausse
}

enum ScriptPlatform {
  TIKTOK
  REELS
  SHORTS
}

/** Niveau du vendeur créateur (système d'encouragement, basé sur les clics cumulés). */
enum CreatorTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  firstName    String
  lastName     String
  role         UserRole  @default(CUSTOMER)
  avatarUrl    String?
  // OAuth (préparé pour Phase ultérieure)
  googleId     String?   @unique
  facebookId   String?   @unique
  appleId      String?   @unique
  // Réinitialisation de mot de passe
  resetTokenHash String?
  resetTokenExpiry DateTime?

  shop          Shop?
  orders        Order[]
  cart          Cart?
  refreshTokens RefreshToken[]
  generatedAssets GeneratedAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Shop {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  slogan      String?
  description String?

  // Branding / Boutique Premium personnalisable
  logoUrl        String?
  bannerUrl      String?
  primaryColor   String?
  secondaryColor String?
  // Affichage sur la vitrine : masquer si la bannière contient déjà le nom/slogan
  showNameOnBanner   Boolean @default(true)
  showSloganOnBanner Boolean @default(true)
  // Placement du logo (top-left|top-right|bottom-left|bottom-right) et cadrage bannière (top|center|bottom)
  logoPosition       String  @default("top-left")
  bannerPosition     String  @default("center")
  // Crédits IA : solde mensuel (réinitialisé chaque mois selon le plan) + date du dernier renouvellement
  aiCredits          Int      @default(0)
  creditsRenewedAt   DateTime?
  // Crédits IA achetés en supplément (recharge Paystack) : reportés, JAMAIS réinitialisés
  aiCreditsExtra     Int      @default(0)
  // ViralAmazone : identifiant de suivi interne (sub-tag) pour attribuer les clics/ventes
  // d'affiliation Amazon à ce vendeur — le compte Associates Amazon est unique et détenu
  // par la plateforme (voir module ViralAmazone), ce tag sert au partage de revenu interne.
  affiliateTrackingId String? @unique

  // Système d'encouragement ViralAmazone (Couche 1 — voir GamificationService)
  totalClicks       Int         @default(0)
  currentStreakDays Int         @default(0)
  longestStreakDays Int         @default(0)
  lastActivityDate  DateTime?
  creatorTier       CreatorTier @default(BRONZE)

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String @unique

  subscription Subscription?
  products     Product[]
  orders       Order[]
  generatedAssets GeneratedAsset[]
  socialConnections SocialConnection[]
  scheduledPosts    ScheduledPost[]
  creditPurchases   CreditPurchase[]
  viralScripts      ViralScript[]
  affiliateClicks   AffiliateClick[]
  rewardEvents      RewardEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

/** Achat ponctuel de crédits IA (recharge) via Paystack. */
model CreditPurchase {
  id          String   @id @default(cuid())
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId      String
  packId      String
  credits     Int
  amount      Decimal  @db.Decimal(12, 2)
  currency    String
  provider    String   @default("paystack")
  providerRef String   @unique
  status      String   @default("PENDING") // PENDING | PAID | FAILED
  couponCode  String? // code promo appliqué (le cas échéant)
  discountEur Decimal? @db.Decimal(10, 2) // remise appliquée en EUR
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId])
}

/**
 * Code promo (ex. FONDATEUR) : remise en % ou montant fixe, appliqué au paiement.
 * `appliesTo` cadre l'usage (credits pour l'instant ; subscription à venir).
 */
model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique // stocké en MAJUSCULES
  description    String?
  percentOff     Int? // 1-100
  amountOffEur   Decimal? @db.Decimal(10, 2)
  appliesTo      String   @default("credits") // credits | order | all
  maxRedemptions Int? // null = illimité
  timesRedeemed  Int      @default(0)
  active         Boolean  @default(true)
  expiresAt      DateTime?

  redemptions CouponRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

/** Utilisation d'un coupon par une boutique (une seule fois par boutique). */
model CouponRedemption {
  id           String  @id @default(cuid())
  coupon       Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  couponId     String
  shopId       String
  context      String // ex: "credits:pack-150"
  amountOffEur Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@unique([couponId, shopId])
  @@index([shopId])
}

model Subscription {
  id        String           @id @default(cuid())
  plan      SubscriptionPlan @default(STARTER)
  active    Boolean          @default(true)
  startedAt DateTime         @default(now())
  expiresAt DateTime?

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String @unique
}

model Product {
  id          String          @id @default(cuid())
  name        String
  description String?
  category    ProductCategory
  price       Decimal         @db.Decimal(10, 2)
  currency    String          @default("EUR")
  status      ProductStatus   @default(DRAFT)
  images      String[]        @default([])
  videos      String[]        @default([])

  // Produit affilié (importé d'un marketplace, ex. ViralAmazone) : lien externe.
  // Quand présent, la vitrine redirige vers ce lien au lieu du panier interne.
  affiliateUrl      String? @db.Text
  sourceMarketplace String? // ex: "amazon.fr" — provenance du produit affilié

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String

  variants   ProductVariant[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  generatedAssets GeneratedAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([category])
  @@index([status])
}

model ProductVariant {
  id            String   @id @default(cuid())
  size          String
  color         String
  sku           String?
  stock         Int      @default(0)
  priceOverride Decimal? @db.Decimal(10, 2)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, size, color])
  @@index([productId])
}

model Cart {
  id     String     @id @default(cuid())
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String     @unique
  items  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id       String @id @default(cuid())
  quantity Int    @default(1)

  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantId String?

  @@unique([cartId, productId, variantId])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  currency    String      @default("EUR")

  customer   User   @relation(fields: [customerId], references: [id])
  customerId String

  shop   Shop   @relation(fields: [shopId], references: [id])
  shopId String

  items   OrderItem[]
  payment Payment?

  shippingAddress Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([shopId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantId String?

  // Instantané du produit au moment de la commande
  productName String
}

model Payment {
  id            String          @id @default(cuid())
  provider      PaymentProvider @default(STRIPE)
  providerRef   String? // ex: Stripe PaymentIntent id
  amount        Decimal         @db.Decimal(10, 2)
  currency      String          @default("EUR")
  paid          Boolean         @default(false)
  rawPayload    Json?

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GeneratedAsset {
  id       String               @id @default(cuid())
  type     GeneratedAssetType
  status   GeneratedAssetStatus @default(READY)
  provider String // "openai" | "anthropic" | "mock"
  prompt   String?
  url      String? // image générée (URL ou data URI)
  meta     Json? // texte publicitaire, options, etc.

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String

  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId String?

  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([type])
}

model SocialConnection {
  id          String    @id @default(cuid())
  network     String // Facebook, Instagram, TikTok, YouTube, Pinterest, X
  connected   Boolean   @default(false)
  accountName String?
  accessToken String? // jeton OAuth (placeholder en mode simulé)
  connectedAt DateTime?

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String

  @@unique([shopId, network])
}

model ScheduledPost {
  id          String    @id @default(cuid())
  caption     String
  imageUrl    String?
  networks    String[]  @default([])
  scheduledAt DateTime
  status      String    @default("SCHEDULED") // SCHEDULED | PUBLISHED | FAILED | CANCELLED
  publishedAt DateTime?

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId String

  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([status])
}

// ────────────────────────────────────────────────────────────────────────
// ViralAmazone Trend Machine — tracker de tendances Amazon + générateur de
// scripts viraux. Données sourcées via Amazon PA-API (officielle) + Keepa
// (historique de rang), jamais par scraping direct.
// ────────────────────────────────────────────────────────────────────────

/** Produit Amazon suivi (identité stable ASIN + marketplace, état courant). */
model AmazonProduct {
  id          String @id @default(cuid())
  asin        String
  marketplace String // domaine Amazon ciblé, ex: "amazon.fr", "amazon.com"
  title       String
  imageUrl    String?
  category    String?
  productUrl  String @db.Text

  // État courant (rafraîchi périodiquement via PA-API/Keepa)
  currentRank   Int?
  currentPrice  Decimal? @db.Decimal(12, 2)
  currency      String?
  reviewCount   Int?
  rating        Decimal? @db.Decimal(3, 2)
  lastCheckedAt DateTime?

  // Vélocité calculée (voir TrendsService) + classification
  velocity3h  Float?
  velocity12h Float?
  velocity24h Float?
  trendTier   TrendTier?

  snapshots AmazonRankSnapshot[]
  scripts   ViralScript[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([asin, marketplace])
  @@index([trendTier])
  @@index([category])
}

/** Relevé horodaté du rang de vente — série temporelle pour le calcul de vélocité. */
model AmazonRankSnapshot {
  id          String        @id @default(cuid())
  product     AmazonProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
  salesRank   Int
  price       Decimal?      @db.Decimal(12, 2)
  reviewCount Int?
  rating      Decimal?      @db.Decimal(3, 2)
  capturedAt  DateTime      @default(now())

  @@index([productId, capturedAt])
}

/** Script vidéo viral généré par IA pour un produit, propre à un vendeur. */
model ViralScript {
  id        String         @id @default(cuid())
  shop      Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId    String
  product   AmazonProduct  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  platform  ScriptPlatform @default(TIKTOK)

  hook     String @db.Text
  problem  String @db.Text
  solution String @db.Text
  cta      String @db.Text

  affiliateUrl String @db.Text
  provider     String // 'anthropic' | 'openai' | 'mock'

  clicks AffiliateClick[]

  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([productId])
}

/**
 * Clic enregistré sur le lien traçant maison (/go/:scriptId) avant redirection vers
 * Amazon. Sert de proxy immédiat à l'intérêt généré (Amazon ne donne aucune donnée
 * de commission en temps réel) — alimente les niveaux, jalons et le classement.
 * Un clic dédupliqué (même boutique+script+IP dans les 30 min) n'est pas ré-inséré.
 */
model AffiliateClick {
  id       String      @id @default(cuid())
  shop     Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId   String
  script   ViralScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  scriptId String
  ipHash   String

  createdAt DateTime @default(now())

  @@index([shopId, createdAt])
  @@index([scriptId, ipHash, createdAt])
}

/**
 * Récompense accordée au vendeur (crédits IA bonus) — jalon de clics, de série,
 * passage de niveau ou classement hebdomadaire. `key` garantit l'octroi UNIQUE
 * (idempotent) par boutique, et sert d'historique visible côté dashboard.
 */
model RewardEvent {
  id      String @id @default(cuid())
  shop    Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId  String
  kind    String // 'CLICK_MILESTONE' | 'STREAK_MILESTONE' | 'TIER_UP' | 'LEADERBOARD'
  key     String // identifiant unique du jalon, ex: 'clicks_100', 'streak_7', 'tier_GOLD'
  credits Int    @default(0)

  createdAt DateTime @default(now())

  @@unique([shopId, key])
  @@index([shopId])
}
